{
  "name": "tms-platform",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start": "dotenv -e .env -- turbo start",
    "dev": "dotenv -e .env -- turbo dev",
    "build": "NODE_ENV=production dotenv -e .env -- turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "test": "dotenv -e .env -- turbo test",
    "db:generate": "dotenv -e .env -- turbo db:generate",
    "db:migrate": "dotenv -e .env -- turbo db:migrate",
    "db:seed": "dotenv -e .env -- turbo db:seed",
    "db:studio": "pnpm --filter @tms/db studio",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "prepare": "husky",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:restart": "pm2 restart ecosystem.config.js",
    "pm2:delete": "pm2 delete ecosystem.config.js",
    "pm2:logs": "pm2 logs",
    "pm2:status": "pm2 status"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.4.2",
    "turbo": "^2.3.4"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
