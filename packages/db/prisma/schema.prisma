// ============================================================
// TMS Platform — Prisma Schema
// PostgreSQL + Prisma ORM
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// CUSTOMER & CARRIER
// ============================================================

model Customer {
  id          String      @id @default(cuid())
  code        String      @unique                                // SAILUN_TAL, FUTIAN_MB
  name        String                                             // SAILUN TAL, FUTIAN MB
  address     String?
  phone       String?
  email       String?
  taxCode     String?     @map("tax_code")
  isActive    Boolean     @default(true) @map("is_active")

  tripPlans   TripPlan[]

  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  @@map("customers")
}

model Carrier {
  id          String      @id @default(cuid())
  code        String      @unique                                // NHA_PHUONG, LUCKY, DTP
  name        String                                             // NHA PHUONG, LUCKY
  phone       String?
  isActive    Boolean     @default(true) @map("is_active")

  tripPlans   TripPlan[]

  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  @@map("carriers")
}

// ============================================================
// LOCATION (Depot, Port, ICD, Industrial Zone)
// ============================================================

model Location {
  id            String        @id @default(cuid())
  code          String        @unique                            // DEPOT_5A, CAT_LAI, KCN_QILU
  name          String
  locationType  LocationType  @map("location_type")
  address       String?
  latitude      Decimal?      @db.Decimal(10, 7)
  longitude     Decimal?      @db.Decimal(10, 7)
  isActive      Boolean       @default(true) @map("is_active")

  yardMoves     YardMove[]

  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  @@map("locations")
}

// ============================================================
// SERVICE TYPE MASTER — Managed lookup table replacing enum
// ============================================================

model ServiceTypeMaster {
  id          String     @id @default(cuid())
  code        String     @unique                                // "SEA-EX", "SEA-IM", "NEO-EX", "NEO-IM"
  description String                                            // "SEA - EXPORT", "SEA - IMPORT"
  isActive    Boolean    @default(true) @map("is_active")
  tripPlans   TripPlan[]

  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  @@map("service_types")
}

// ============================================================
// CONTAINER SIZE MASTER — Managed lookup table
// ============================================================

model ContainerSize {
  id        String     @id @default(cuid())
  code      String     @unique                                  // "20GP", "40HC", "45HC"
  name      String                                              // "20ft General Purpose"
  isActive  Boolean    @default(true) @map("is_active")
  tripPlans TripPlan[]

  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  @@map("container_sizes")
}

// ============================================================
// COST TEMPLATE — Suggestion-only catalog for cost comboboxes
// ============================================================

model CostTemplate {
  id            String   @id @default(cuid())
  name          String
  defaultAmount Decimal? @db.Decimal(15, 2) @map("default_amount")
  isActive      Boolean  @default(true) @map("is_active")

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("cost_templates")
}

// ============================================================
// TRIP PLAN — Core dispatch entity
// ============================================================

model TripPlan {
  id              String          @id @default(cuid())
  tripDate        DateTime        @map("trip_date") @db.Date
  tripNumber      Int?            @map("trip_number")              // STT
  listSortedAt    DateTime        @default(now()) @map("list_sorted_at") // bumped on create/import-touch, default sort key

  // Service classification — FK to ServiceTypeMaster
  serviceTypeId   String?         @map("service_type_id")
  serviceTypeMaster ServiceTypeMaster? @relation(fields: [serviceTypeId], references: [id])
  tripMode        TripMode        @default(STANDARD) @map("trip_mode")
  status          TripStatus      @default(PLANNED)

  // Vehicle plate stored as plain string (no FK to Vehicle table)
  vehiclePlate    String?         @map("vehicle_plate")

  customerId      String          @map("customer_id")
  customer        Customer        @relation(fields: [customerId], references: [id])

  carrierId       String?         @map("carrier_id")
  carrier         Carrier?        @relation(fields: [carrierId], references: [id])

  // Container tracking — FK to ContainerSize + plain strings
  containerSizeId         String?  @map("container_size_id")
  containerSize           ContainerSize? @relation(fields: [containerSizeId], references: [id])
  outboundContainerNumber String?  @map("outbound_container_number")
  inboundContainerNumber  String?  @map("inbound_container_number")

  // 3-point route — denormalized name strings (no FK)
  pickupLocationName      String?  @map("pickup_location_name")     // Điểm Lấy (R/H)
  loadUnloadLocationName  String?  @map("load_unload_location_name") // Điểm Đóng/Rút
  dropoffLocationName     String?  @map("dropoff_location_name")    // Điểm hạ (R/H)

  // Cost breakdown (M:N via TripPlanCost) — used for "chi phí phát sinh"
  costs           TripPlanCost[]

  // Denormalized last-added cost (customer requirement)
  tripCostName    String?         @map("trip_cost_name")
  tripCostAmount  Decimal?        @db.Decimal(15, 2) @map("trip_cost_amount")

  // Fixed cost slots — name+amount snapshot (8 slots)
  phiNangName           String?   @map("phi_nang_name")
  phiNangAmount         Decimal?  @db.Decimal(15, 2) @map("phi_nang_amount")
  shdNang               String?   @map("shd_nang")

  phiHaName             String?   @map("phi_ha_name")
  phiHaAmount           Decimal?  @db.Decimal(15, 2) @map("phi_ha_amount")
  shdHa                 String?   @map("shd_ha")

  phiVeSinhName         String?   @map("phi_ve_sinh_name")
  phiVeSinhAmount       Decimal?  @db.Decimal(15, 2) @map("phi_ve_sinh_amount")
  shdVeSinh             String?   @map("shd_ve_sinh")

  phiCuocName           String?   @map("phi_cuoc_name")
  phiCuocAmount         Decimal?  @db.Decimal(15, 2) @map("phi_cuoc_amount")

  veCongName            String?   @map("ve_cong_name")
  veCongAmount          Decimal?  @db.Decimal(15, 2) @map("ve_cong_amount")
  shdVeCong             String?   @map("shd_ve_cong")

  chiPhiKhacName        String?   @map("chi_phi_khac_name")
  chiPhiKhacAmount      Decimal?  @db.Decimal(15, 2) @map("chi_phi_khac_amount")

  chiPhiTraiTuyenName   String?   @map("chi_phi_trai_tuyen_name")
  chiPhiTraiTuyenAmount Decimal?  @db.Decimal(15, 2) @map("chi_phi_trai_tuyen_amount")

  cauDuongName          String?   @map("cau_duong_name")
  cauDuongAmount        Decimal?  @db.Decimal(15, 2) @map("cau_duong_amount")

  // Document tracking
  documentSentDate DateTime?     @map("document_sent_date") @db.Date  // Ngày gửi CT
  description     String?                                              // NỘI DUNG
  notes           String?

  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  @@index([tripDate])
  @@index([customerId])
  @@index([vehiclePlate])
  @@index([status])
  @@index([serviceTypeId])
  @@map("trip_plans")
}

// ============================================================
// TRIP PLAN COSTS — Chi phí chuyến hàng
// ============================================================

model TripPlanCost {
  id            String    @id @default(cuid())
  tripPlanId    String    @map("trip_plan_id")
  tripPlan      TripPlan  @relation(fields: [tripPlanId], references: [id], onDelete: Cascade)

  costName      String?   @map("cost_name")
  amount        Decimal   @db.Decimal(15, 2)
  invoiceNumber String?   @map("invoice_number")                  // SHĐ (số hóa đơn)

  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([tripPlanId])
  @@map("trip_plan_costs")
}

// ============================================================
// YARD MOVE — Internal factory yard shuttle operations
// ============================================================

model YardMove {
  id              String          @id @default(cuid())
  date            DateTime        @db.Date
  containerNumber String          @map("container_number")         // ISO 6346: 4 letters + 7 digits
  fromZone        String          @map("from_zone")                // STAGING_DROP | LOADING_DOCK | STAGING_READY
  toZone          String          @map("to_zone")
  locationId      String          @map("location_id")              // Factory where the move occurs
  location        Location        @relation(fields: [locationId], references: [id])
  status          YardMoveStatus  @default(PENDING)
  isActive        Boolean         @default(true) @map("is_active")
  notes           String?
  costs           YardMoveCost[]

  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  @@index([locationId])
  @@index([status])
  @@index([containerNumber])
  @@map("yard_moves")
}

model YardMoveCost {
  id          String        @id @default(cuid())
  yardMoveId  String        @map("yard_move_id")
  yardMove    YardMove      @relation(fields: [yardMoveId], references: [id], onDelete: Cascade)
  type        YardCostType  @map("type")
  amount      Decimal       @db.Decimal(15, 2)
  note        String?

  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  @@index([yardMoveId])
  @@map("yard_move_costs")
}

// ============================================================
// ENUMS
// ============================================================

enum LocationType {
  PORT              // Cảng: Cát Lái, HBCX TCTT, HBCX SSIT
  DEPOT             // Depot: DEPOT 5A, GREEN LT, SOTRANS
  ICD               // ICD: ICD Sóng Thần
  INDUSTRIAL_ZONE   // KCN: KCN Qilu, CVT
  WAREHOUSE
  OTHER
}

enum TripStatus {
  PLANNED
  DISPATCHED
  IN_TRANSIT
  COMPLETED
  CANCELLED
}

enum TripMode {
  STANDARD          // Xe chờ đóng hàng (regular trip)
  DROP_AND_HOOK     // Cắt kéo (CONT ĐI ≠ CONT VỀ)
}

enum YardMoveStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum YardCostType {
  YARD_HANDLING     // Phí dọn bãi
  FORKLIFT          // Phí xe nâng
  OVERTIME          // Phí tăng ca
  OTHER
}

// ============================================================
// AUDIT LOG — Append-only audit trail
// ============================================================

model AuditLog {
  id             String      @id @default(cuid())
  actorUserId    String?     @map("actor_user_id")
  actorUsername  String?     @map("actor_username")
  actorRole      String?     @map("actor_role")
  action         AuditAction
  entityType     String      @map("entity_type")
  entityId       String?     @map("entity_id")
  summary        String
  beforeSnapshot Json?       @map("before_snapshot")
  afterSnapshot  Json?       @map("after_snapshot")
  metadata       Json?
  ipAddress      String?     @map("ip_address")
  userAgent      String?     @map("user_agent")
  createdAt      DateTime    @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================================
// USER & AUTH
// ============================================================

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String   @map("password_hash")
  role         Role     @default(OPERATOR)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("users")
}

enum Role {
  ADMIN
  OPERATOR
  VIEWER
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
  COST_ADDED
  LOGIN
  LOGIN_FAILED
  LOGOUT
  REGISTER
}

// ============================================================
// VEHICLE RECORD MANAGEMENT (standalone, no FK to vehicles/drivers)
// ============================================================

model VehicleRecord {
  id              String                      @id @default(cuid())
  tenTaiXe        String?                     @map("ten_tai_xe")       // Tên tài xế
  sdt             String?                                              // Số điện thoại
  loaiXe          String?                     @map("loai_xe")          // Loại xe
  bienSo          String?                     @map("bien_so")          // Biển số / Theo xe
  hanDangKiem     DateTime?                   @map("han_dang_kiem")    // Hạn đăng kiểm xe
  hanBaoHiem      DateTime?                   @map("han_bao_hiem")     // Hạn bảo hiểm xe
  hanCaVet        DateTime?                   @map("han_ca_vet")       // Hạn cà vẹt xe
  ghiChu          String?                     @map("ghi_chu")
  donViSuaChua    String?                     @map("don_vi_sua_chua")  // Đơn vị sửa chữa bảo dưỡng
  ngayLam         DateTime?                   @map("ngay_lam") @db.Date // Ngày làm bảo dưỡng gần nhất
  kmHienTai       String?                     @map("km_hien_tai")      // Số KM hiện tại
  ghiChuBaoDuong  String?                     @map("ghi_chu_bao_duong") // Ghi chú bảo dưỡng (khác ghiChu của quản lý xe)
  moocs           VehicleRecordMooc[]
  kmRounds        VehicleMaintenanceKmRound[]
  createdAt       DateTime                    @default(now()) @map("created_at")
  updatedAt       DateTime                    @updatedAt @map("updated_at")

  @@map("vehicle_records")
}

model VehicleRecordMooc {
  id              String        @id @default(cuid())
  vehicleRecordId String        @map("vehicle_record_id")
  vehicleRecord   VehicleRecord @relation(fields: [vehicleRecordId], references: [id], onDelete: Cascade)
  soMooc          String        @map("so_mooc")
  hanDangKiem     DateTime?     @map("han_dang_kiem")
  hanBaoHiem      DateTime?     @map("han_bao_hiem")
  hanCaVet        DateTime?     @map("han_ca_vet")

  @@map("vehicle_record_moocs")
}

// ============================================================
// VEHICLE MAINTENANCE — KM ROUNDS — Bảo dưỡng xe (km từng lần)
// ============================================================

model VehicleMaintenanceKmRound {
  id              String        @id @default(cuid())
  vehicleRecordId String        @map("vehicle_record_id")
  vehicleRecord   VehicleRecord @relation(fields: [vehicleRecordId], references: [id], onDelete: Cascade)
  roundNumber     Int           @map("round_number")
  kmCon           String        @map("km_con")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  @@unique([vehicleRecordId, roundNumber])
  @@index([vehicleRecordId])
  @@map("vehicle_maintenance_km_rounds")
}
